{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Mermaid",
  "scopeName": "source.mermaid",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#frontmatter"
    },
    {
      "include": "#diagramKeywords"
    },
    {
      "include": "#controlKeywords"
    },
    {
      "include": "#arrows"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#operators"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.percentage.mermaid",
          "match": "%%.*$"
        }
      ]
    },
    "frontmatter": {
      "patterns": [
        {
          "name": "meta.frontmatter.mermaid",
          "begin": "^---\\s*$",
          "end": "^---\\s*$",
          "patterns": [
            {
              "match": "^[A-Za-z_][A-Za-z0-9_-]*(?=\\s*:)",
              "name": "variable.other.readwrite.mermaid"
            },
            {
              "include": "#strings"
            },
            {
              "include": "#numbers"
            }
          ]
        }
      ]
    },
    "diagramKeywords": {
      "patterns": [
        {
          "name": "keyword.control.diagram.mermaid",
          "match": "^\\s*(?:graph|flowchart|sequenceDiagram|classDiagram|stateDiagram(?:-v2)?|erDiagram|journey|gantt|pie|mindmap|timeline|gitGraph|quadrantChart|requirementDiagram|xychart-beta|block-beta|architecture-beta|packet-beta|kanban|sankey-beta|radar-beta)\\b"
        }
      ]
    },
    "controlKeywords": {
      "patterns": [
        {
          "name": "keyword.other.mermaid",
          "match": "\\b(?:subgraph|direction|participant|actor|loop|alt|opt|par|and|else|end|Note|section|classDef|class|style|linkStyle|click|title|state|choice|fork|join|namespace|accTitle|accDescr)\\b"
        }
      ]
    },
    "arrows": {
      "patterns": [
        {
          "name": "keyword.operator.arrow.mermaid",
          "match": "(?:<-->|-->>|->>|<--|-->|==>|===|-.->|---|--|<-|->)"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.mermaid",
          "begin": "\"",
          "end": "\""
        },
        {
          "name": "string.quoted.single.mermaid",
          "begin": "'",
          "end": "'"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.mermaid",
          "match": "\\b\\d+(?:\\.\\d+)?\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "punctuation.definition.parameters.mermaid",
          "match": "[{}()\\[\\]|:]"
        }
      ]
    }
  }
}